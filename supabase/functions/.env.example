# Copy to supabase/functions/.env for local dev -- `supabase functions serve` loads it
# automatically. Never commit the real file (it's gitignored alongside supabase/.env).
#
# Without these, send-whatsapp still runs and logs the exact request payload to
# whatsapp_log with status 'queued' -- it just skips the real network call. Fill
# these in once you've set up a Meta Business account + WhatsApp Cloud API app.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v22.0

# Pick any random string yourself (e.g. `openssl rand -hex 20`) -- it's not issued by Meta.
# Paste the same value into the Meta App Dashboard's WhatsApp > Configuration > Webhook
# "Verify token" field. Callback URL there is:
#   https://<project-ref>.supabase.co/functions/v1/whatsapp-webhook
# (local dev: http://127.0.0.1:54321/functions/v1/whatsapp-webhook, but Meta needs a
# publicly reachable HTTPS URL -- use `supabase functions deploy whatsapp-webhook` first,
# or tunnel local dev with something like ngrok if you need to test the handshake pre-deploy.)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Base URL of the deployed mweb app, used to build the public bill link sent in the
# "bill ready" WhatsApp message. Defaults to the local Expo web dev server.
PUBLIC_WEB_BASE_URL=http://localhost:8081

# Optional: a Discord channel webhook URL. If set, whatsapp-webhook posts a line to it for
# every verification attempt, delivery-status update, and inbound message -- since inbound
# messages aren't persisted anywhere else yet, this is the only visibility into them.
# Create one via Discord: channel Settings > Integrations > Webhooks > New Webhook.
DISCORD_WEBHOOK_URL=

# Shared initial/reset password for every customer and shop-owner login (WhatsApp templates
# can't reveal a per-user credential -- see create-customer/create-shop/regenerate-customer-password).
# Pick your own value; customers change it in-app after first login.
DEFAULT_PASSWORD=
