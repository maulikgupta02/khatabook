# Copy to supabase/functions/.env for local dev -- `supabase functions serve` loads it
# automatically. Never commit the real file (it's gitignored alongside supabase/.env).
#
# Without these, send-whatsapp still runs and logs the exact request payload to
# whatsapp_log with status 'queued' -- it just skips the real network call. Fill
# these in once you've set up a Meta Business account + WhatsApp Cloud API app.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v22.0

# Base URL of the deployed mweb app, used to build the public bill link sent in the
# "bill ready" WhatsApp message. Defaults to the local Expo web dev server.
PUBLIC_WEB_BASE_URL=http://localhost:8081
